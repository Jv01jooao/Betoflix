<Window x:Class="Netflix.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Netflix"
        xmlns:moviserie="clr-namespace:Netflix.View.moviserie"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="Black" Height="Auto" Width="Auto">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="65"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Height="35">
            <Rectangle Fill="Gray" Height="20" Width="20" HorizontalAlignment="Left" Margin="5,0,0,0"/>
            <TextBlock Text="'" FontSize="16" Foreground="Gray" HorizontalAlignment="Left" Margin="30,10,0,0"/>
            
            <TextBlock x:Name="Search" Text="🔍️" HorizontalAlignment="Center" Margin="0,5,380,0" FontSize="16" Foreground="AliceBlue" Panel.ZIndex="5" MouseEnter="TextBlock_MouseEnter" MouseLeave="Search_MouseLeave" MouseLeftButtonDown="Search_MouseLeftButtonDown"/>
            
            <Rectangle x:Name="Searchfundo" Visibility="Collapsed" Fill="Gray" Height="25" Width="25" HorizontalAlignment="Center" Margin="0,2,380,0" RadiusX="5" RadiusY="5"/>
            
            <TextBlock x:Name="Home" Text="Home" HorizontalAlignment="Center" Margin="0,5,250,0" FontSize="16" FontWeight="Bold" Foreground="AliceBlue" Background="Transparent" Panel.ZIndex="5" MouseEnter="Home_MouseEnter" MouseLeave="Home_MouseLeave" MouseLeftButtonDown="Home_MouseLeftButtonDown"/>
            
            <Rectangle x:Name="Homefundo" Visibility="Collapsed" Fill="Gray" Height="20" Width="60" HorizontalAlignment="Center" Margin="0,2,250,0" RadiusX="5" RadiusY="5"/>
           
            <TextBlock Text="Shows"  HorizontalAlignment="Center" Margin="0,5,100,0" FontSize="16" FontWeight="Bold" Foreground="AliceBlue" Panel.ZIndex="5" MouseEnter="TextBlock_MouseEnter_1" MouseLeave="TextBlock_MouseLeave"/>
            
            <Rectangle x:Name="Showfundo" Visibility="Collapsed" Fill="Gray" Height="20" Width="60" HorizontalAlignment="Center" Margin="0,2,100,0" RadiusX="5" RadiusY="5"/>
            
            <TextBlock Text="Movies" HorizontalAlignment="Center" Margin="0,5,-60,0" FontSize="16" FontWeight="Bold" Foreground="AliceBlue" Panel.ZIndex="5" MouseEnter="TextBlock_MouseEnter_2" MouseLeave="TextBlock_MouseLeave_1"/>
           
            <Rectangle x:Name="Moviesfundo" Visibility="Collapsed" Fill="Gray" Height="20" Width="60" HorizontalAlignment="Center" Margin="0,2,-60,0" RadiusX="5" RadiusY="5"/>
            
            <TextBlock Text="My Netflix" HorizontalAlignment="Center" Margin="0,5,-240,0" FontSize="16" FontWeight="Bold" Foreground="AliceBlue" Panel.ZIndex="5" MouseEnter="TextBlock_MouseEnter_3" MouseLeave="TextBlock_MouseLeave_2"/>
           
            <Rectangle x:Name="MyNetflixfundo" Visibility="Collapsed" Fill="Gray" Height="20" Width="85" HorizontalAlignment="Center" Margin="0,2,-240,0" RadiusX="5" RadiusY="5"/>
           
            <TextBlock Text="B" HorizontalAlignment="Center" Margin="0,0,-755,5" FontSize="30" FontWeight="Bold" Foreground="Red"/>
        </Grid>
        <Grid x:Name="GridHome" Height="403" Width="810" Margin="-10,0,0,-338" Grid.Row="1">
            <TextBlock Text="My List" Foreground="AliceBlue" FontSize="16" FontWeight="Bold" Margin="15,5,0,0" Height="20" TextAlignment="Center" Width="60" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <StackPanel Orientation="Horizontal" Margin="17,30,0,0">
                <moviserie:moviserie Margin="0,0,10,0"/>
                <moviserie:moviserie Margin="0,0,10,0"/>
                <moviserie:moviserie Margin="0,0,10,0"/>
            </StackPanel>

            <TextBlock Text="Continue Watching" Foreground="AliceBlue" FontSize="16" FontWeight="Bold" Margin="17,210,0,0" Height="20" TextAlignment="Center" Width="145" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            
            <StackPanel Orientation="Horizontal" Margin="17,240,0,0">
                <moviserie:moviserie Margin="0,0,10,0"/>
                <moviserie:moviserie Margin="0,0,10,0"/>
                <moviserie:moviserie Margin="0,0,10,0"/>
            </StackPanel>
            <Grid x:Name="GridSearch" Background="Black" Visibility="Collapsed">
                <TextBlock x:Name="SearchTextblock" FontSize="16" Foreground="AliceBlue" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0" FontWeight="Bold" />
                <TextBox x:Name="SearchTextbox" Width="500" Height="25" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,45,0,0" Foreground="AliceBlue" Background="Black" TextChanged="TextBox_TextChanged"/>
                <StackPanel x:Name="quadradSearch" Visibility="Collapsed" Orientation="Horizontal" Margin="230,130,0,0">
                    <moviserie:moviserie Margin="0,0,10,0"/>
                    <moviserie:moviserie Margin="0,0,10,0"/>
                    <moviserie:moviserie Margin="0,0,10,0"/>
                </StackPanel>
            </Grid>
        </Grid>
        
    </Grid>
</Window>
